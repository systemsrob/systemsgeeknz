---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Systems Geek NZ',
  description = 'Consultancy, development, and system administration for small business.'
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0b0f14" />

    <style is:global>
      :root {
        --bg: #0b0f14;
        --bg-soft: #121821;
        --panel: #161d27;
        --text: #e6edf3;
        --muted: #9fb0c3;
        --line: #263241;
        --accent: #67b7ff;
        --accent-soft: rgba(103, 183, 255, 0.12);
        --max-width: 1100px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        background:
          radial-gradient(circle at top, rgba(103, 183, 255, 0.08), transparent 30%),
          linear-gradient(180deg, #0b0f14 0%, #0d1218 100%);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      .container {
        width: min(100% - 2rem, var(--max-width));
        margin: 0 auto;
      }

      .site-header {
        border-bottom: 1px solid var(--line);
        background: rgba(11, 15, 20, 0.78);
        backdrop-filter: blur(10px);
        position: sticky;
        top: 0;
        z-index: 20;
      }

      .site-header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        min-height: 72px;
        gap: 1rem;
      }

      .brand {
        font-size: 1.05rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        color: var(--text);
      }

      .brand span {
        color: var(--accent);
      }

      .nav {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .nav a {
        color: var(--muted);
        font-size: 0.95rem;
      }

      .nav a:hover {
        color: var(--text);
        text-decoration: none;
      }

      .hero {
        padding: 6rem 0 4rem;
      }

      .hero-grid {
        display: grid;
        grid-template-columns: 1.35fr 0.9fr;
        gap: 2rem;
        align-items: center;
      }

      .eyebrow {
        display: inline-block;
        padding: 0.45rem 0.75rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent);
        font-size: 0.85rem;
        margin-bottom: 1rem;
      }

      h1 {
        margin: 0 0 1rem;
        font-size: clamp(2.2rem, 5vw, 4.5rem);
        line-height: 1.05;
        letter-spacing: -0.03em;
      }

      .hero p {
        margin: 0;
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.7;
        max-width: 60ch;
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 2rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 44px;
        padding: 0.8rem 1.2rem;
        border-radius: 0.8rem;
        font-weight: 600;
        border: 1px solid var(--line);
        transition: 0.18s ease;
      }

      .button-primary {
        background: var(--accent);
        color: #081018;
        border-color: var(--accent);
      }

      .button-primary:hover {
        text-decoration: none;
        transform: translateY(-1px);
      }

      .button-secondary {
        background: transparent;
        color: var(--text);
      }

      .button-secondary:hover {
        text-decoration: none;
        background: var(--bg-soft);
      }

      .card {
        background: linear-gradient(180deg, rgba(255,255,255,0.02), rgba(255,255,255,0.01));
        border: 1px solid var(--line);
        border-radius: 1.2rem;
        padding: 1.25rem;
        box-shadow: 0 12px 40px rgba(0,0,0,0.25);
      }

      .stack {
        display: grid;
        gap: 1rem;
      }

      .stat-title {
        color: var(--muted);
        font-size: 0.9rem;
        margin-bottom: 0.35rem;
      }

      .stat-value {
        font-size: 1.2rem;
        font-weight: 700;
      }

      section {
        padding: 2rem 0 4rem;
      }

      .section-title {
        font-size: 1.8rem;
        margin: 0 0 0.75rem;
      }

      .section-copy {
        color: var(--muted);
        line-height: 1.7;
        max-width: 70ch;
        margin: 0 0 2rem;
      }

      .services {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
      }

      .service h3 {
        margin-top: 0;
        margin-bottom: 0.75rem;
        font-size: 1.1rem;
      }

      .service p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .contact-box {
        display: flex;
        justify-content: space-between;
        gap: 1.5rem;
        align-items: center;
      }

      .contact-box p {
        margin: 0;
        color: var(--muted);
        line-height: 1.7;
      }

      .site-footer {
        border-top: 1px solid var(--line);
        padding: 1.5rem 0 2.5rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      @media (max-width: 900px) {
        .hero-grid,
        .services,
        .contact-box {
          grid-template-columns: 1fr;
          display: grid;
        }

        .site-header-inner {
          padding: 0.75rem 0;
        }

        .hero {
          padding-top: 4rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header-inner">
        <a class="brand" href="/">
          Systems <span>Geek NZ</span>
        </a>

        <nav class="nav">
          <a href="#services">Services</a>
          <a href="#about">About</a>
          <a href="#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        © {new Date().getFullYear()} Systems Geek NZ. All rights reserved.
      </div>
    </footer>
  </body>
</html>
